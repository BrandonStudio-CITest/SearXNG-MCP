{
  "name": "@bs-mcps/searxng",
  "version": "0.4.0-dev.2",
  "description": "MCP server for SearXNG",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "bs-mcps-searxng": "dist/cli.js"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').writeFileSync('src/version.ts', 'export const version = ' + JSON.stringify(require('./package.json').version) + ';\\n')\"",
    "build": "tsup src/cli.ts src/searxng.ts src/plugins.ts --format esm --dts --minify",
    "start": "node dist/cli.js",
    "test": "pwsh -File tests/run_test.ps1",
    "test:cf": "pwsh -File tests/run_test_cf.ps1",
    "predeploy": "npm run prebuild",
    "deploy": "wrangler deploy --keep-vars",
    "wrangler:dev": "wrangler dev src/cf-worker.ts",
    "publish:dev": "npm publish --tag=dev"
  },
  "keywords": [
    "ai",
    "mcp",
    "searxng",
    "search",
    "metasearch",
    "model-context-protocol"
  ],
  "author": "BrandonStudio",
  "license": "Apache-2.0",
  "homepage": "https://github.com/BrandonStudio/SearXNG-MCP",
  "bugs": {
    "url": "https://github.com/BrandonStudio/SearXNG-MCP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrandonStudio/SearXNG-MCP.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./searxng": {
      "types": "./dist/searxng.d.ts",
      "import": "./dist/searxng.js",
      "require": "./dist/searxng.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.js"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.10.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^24.12.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.1"
  }
}
